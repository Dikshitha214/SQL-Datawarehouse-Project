/*
=============================================================
# /*

# Create Database and Schemas

Script Purpose:
This script creates a new database named 'DataWarehouse'. Before creating it, the script checks whether the database already exists. If it does, the existing database is dropped and a fresh database is created. After the database is created, three schemas are added to organize data across different stages of the ETL process:
- bronze
- silver
- gold

Warning:
Executing this script will permanently delete the existing 'DataWarehouse' database, including all tables, data, and other database objects. Ensure that any required data has been backed up before running this script.
*/


USE master;
GO

-- Drop and recreate the 'DataWarehouse' database
IF EXISTS (SELECT 1 FROM sys.databases WHERE name = 'DataWarehouse')
BEGIN
    ALTER DATABASE DataWarehouse SET SINGLE_USER WITH ROLLBACK IMMEDIATE;
    DROP DATABASE DataWarehouse;
END;
GO

-- Create the 'DataWarehouse' database
CREATE DATABASE DataWarehouse;
GO

USE DataWarehouse;
GO

-- Create Schemas
CREATE SCHEMA bronze;
GO

CREATE SCHEMA silver;
GO

CREATE SCHEMA gold;
GO
